# Local non-docker run only — docker-compose injects these via `environment:` blocks.

# Postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fleet

# Redis (fanout + sessions)
REDIS_URL=redis://localhost:6379/0
FLEET_CHANNEL=fleet:events

# Session TTL
SESSION_TTL_SECONDS=28800

# Anomaly thresholds (also defined in backend/app/config.py)
SPEED_LIMIT_MPS=5.0
LOW_BATTERY_PCT=15
RAPID_BATTERY_DROP_PCT=10
